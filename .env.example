# One free subdomain → DuckDNS: archie.duckdns.org → VPS IP
DOMAIN=archie.duckdns.org
ACME_EMAIL=you@email.com

PUBLIC_URL=https://archie.duckdns.org
ADMIN_ORIGIN=https://archie.duckdns.org
ADMIN_SECRET=change-me-to-random-32-chars

# Postgres (local Docker — DB_HOST/PORT/USERNAME/NAME overridden by docker-compose)
DB_HOST=db
DB_PORT=5432
DB_USERNAME=archie
DB_PASSWORD=change-me-strong-password
DB_NAME=archie

# Slack — Event URL: https://archie.duckdns.org/slack/events
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=

# AI
OPENAI_API_KEY=sk-...
PINECONE_API_KEY=

# Confluence indexing (Atlassian API token from id.atlassian.com)
CONFLUENCE_EMAIL=
CONFLUENCE_API_TOKEN=

# Optional extra hosts for URL indexing (comma-separated)
# INDEX_URL_ALLOWLIST=wiki.example.com

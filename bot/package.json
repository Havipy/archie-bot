{
  "name": "bot",
  "version": "0.0.1",
  "description": "NestJS Slack RAG bot — Bolt, Pinecone, OpenAI, Postgres",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/src/main.js",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "seed": "ts-node -r tsconfig-paths/register scripts/seed.ts",
    "reindex": "ts-node -r tsconfig-paths/register scripts/reindex.ts",
    "rag:eval": "ts-node -r tsconfig-paths/register scripts/rag-eval.ts",
    "typeorm": "typeorm-ts-node-commonjs -d src/database/persistence/data-source.ts",
    "migration:create": "typeorm-ts-node-commonjs migration:create src/database/persistence/migrations/$npm_config_name",
    "migration:up": "pnpm run typeorm -- migration:run",
    "migration:down": "pnpm run typeorm -- migration:revert",
    "migration:show": "pnpm run typeorm -- migration:show"
  },
  "dependencies": {
    "@langchain/core": "^1.1.48",
    "@langchain/textsplitters": "^1.0.1",
    "@nestjs/common": "^11.0.1",
    "@nestjs/core": "^11.0.1",
    "@nestjs/platform-express": "^11.1.24",
    "@nestjs/serve-static": "^5.0.5",
    "@nestjs/typeorm": "^11.0.1",
    "@pinecone-database/pinecone": "^7.2.0",
    "@slack/bolt": "^4.7.3",
    "@slack/types": "^2.21.1",
    "axios": "^1.17.0",
    "cheerio": "^1.2.0",
    "dotenv": "^17.4.2",
    "express": "^5.1.0",
    "hbs": "^4.2.1",
    "mammoth": "^1.12.0",
    "multer": "^2.1.1",
    "openai": "^6.42.0",
    "pdf-parse": "^2.4.5",
    "pg": "^8.21.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.30",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/cheerio": "^0.22.35",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^24.0.0",
    "@types/pdf-parse": "^1.1.5",
    "@types/supertest": "^7.0.0",
    "@types/uuid": "^10.0.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^17.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  },
  "packageManager": "pnpm@10.24.0+sha512.01ff8ae71b4419903b65c60fb2dc9d34cf8bb6e06d03bde112ef38f7a34d6904c424ba66bea5cdcf12890230bf39f9580473140ed9c946fef328b6e5238a345a"
}
